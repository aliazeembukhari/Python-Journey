   "source": [
    "**Dictionary stores data with keys**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "aab301f7-3b44-4bae-92f7-0466cdd11c32",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "{'name': 'Ali', 'year': 1, 'course': 'Python'}\n"
     ]
    }
   ],
   "source": [
    "my1 = {\n",
    "    \"name\" : \"Ali\",\n",
    "    \"year\" : 1,\n",
    "    \"course\" : \"Python\"\n",
    "}\n",
    "print(my1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "1f882150-fb47-47fa-a5a0-da4679b752f1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Ali\n",
      "Python\n"
     ]
    }
   ],
   "source": [
    "print(my1[\"name\"])\n",
    "print(my1.get(\"course\"))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2a9604ed-4540-45ea-8625-1b4035103d9a",
   "metadata": {},
   "source": [
